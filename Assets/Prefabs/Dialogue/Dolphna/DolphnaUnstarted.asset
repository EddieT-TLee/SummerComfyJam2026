        dialogue: {fileID: 11400000, guid: 2d83257ac454aff459c95714a4d580d8, type: 2}
      choiceText: Sure!
      portraitIndex: 0
      chudLines:
      - text: Thank you so much! I knew I could count on you!
        portraitIndex: 0
        choices: []
      - text: There's a Whack-A-Mole machine in the bar. I never beat the high score
          on it.
        portraitIndex: 0
        choices: []
      - text: Please beat it for me!
        portraitIndex: 0
        choices: []
